<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Daisy не sandboxed (см. ENABLE_APP_SANDBOX=NO в build settings):
	     dictation нужен системный CGEvent.post(⌘V) в произвольный
	     frontmost-процесс, что несовместимо с App Sandbox.
	     Hardened Runtime + Notarization остаются включены, этого
	     достаточно для Gatekeeper при distribution через DMG + Sparkle.

	     Mac App Store не планируется.

	     ─── Hardened Runtime gotcha ──────────────────────────────────
	     Все entitlements ниже — НЕ только sandbox-ключи. Под Hardened
	     Runtime macOS 14+ tccd явно требует их для показа TCC prompt'а
	     соответствующего сервиса. Симптом отсутствия:
	     `requestAccess` возвращает granted=false без throw, диалог не
	     появляется, статус остаётся .notDetermined, app никогда не
	     появляется в System Settings → Privacy → <Service>. В tccd
	     log пишется:
	         "Prompting policy for hardened runtime; service:
	          kTCCService<X> requires entitlement
	          com.apple.security.<X> but it is missing"

	     Если будут добавляться новые services (Contacts / Photos /
	     Reminders / Location / Camera) — нужно одновременно добавлять
	     соответствующий `personal-information.*` или `device.*` key
	     сюда И `NS<X>UsageDescription` в Info.plist. -->

	<!-- Микрофон — без него AudioRecorder получает silent buffer.
	     Требование зафиксировано в tccd log 2026-05-20:
	     "kTCCServiceMicrophone requires com.apple.security.device.audio-input". -->
	<key>com.apple.security.device.audio-input</key>
	<true/>

	<!-- Calendar — для EKEventStore.requestFullAccessToEvents(). -->
	<key>com.apple.security.personal-information.calendars</key>
	<true/>

	<!-- Network client — для Sparkle update checks, OpenAI/Anthropic
	     API, Google Calendar OAuth + API, любого HTTPS-запроса. Под
	     Hardened Runtime non-sandboxed формально не обязателен (этот
	     entitlement gating-ит только Sandbox), но включён explicitly
	     чтобы избежать сюрпризов если когда-нибудь решим обратно
	     включить Sandbox. -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Network server — нужен для MCPServer's NWListener на 127.0.0.1:54321.
	     Под Hardened Runtime macOS 14+ NWListener.bind возвращает
	     `Network.NWError error 1 - Operation not permitted` (EPERM, не
	     EADDRINUSE) без этого entitlement даже на loopback. Symptom
	     зафиксирован в build 33 logs:
	         "MCP listener failed: Operation not permitted"
	     Apple DTS thread 740051 подтверждает: EPERM на NWListener.bind
	     = policy denial, нужен `com.apple.security.network.server` даже
	     non-sandboxed под Hardened Runtime. -->
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
