    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Daisy records meeting audio locally to transcribe it on-device. No audio leaves your computer."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Daisy записывает звук встречи локально и расшифровывает его на устройстве. Аудио не покидает ваш компьютер."
          }
        }
      }
    },
    "NSScreenCaptureUsageDescription" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daisy захватывает системный звук встреч через «Запись экрана», чтобы расшифровывать речь других участников. Видеокадры не сохраняются и никуда не отправляются."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Daisy uses on-device speech recognition to show a lighter live transcript while you record. Everything stays on your Mac — nothing is sent to Apple or any server."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Daisy использует распознавание речи на устройстве, чтобы показывать облегчённый живой транскрипт во время записи. Всё остаётся на вашем Mac — ничего не отправляется Apple или на серверы."
          }
        }
      }
    }
  },
  "version" : "1.0"
