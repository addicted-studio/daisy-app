    "%@: %@" : {
      "comment" : "A label that describes the accessibility of the button. The first argument is the string “Website”, the string “Support”, the string “Source code”, the string “Community”, the string “License”, the string “Privacy”, the string “Contact”, or the string “Made by”. The second argument is the string “mydaisy.io”, the string “mydaisy.io/support”, the string “github.com/addicted-studio/daisy-app”, the string “Q&A, ideas, show-and-tell”, the string “Apache 2.0 — open source”, the string “mydaisy.io/privacy”, the string “essazanov@pm.me”, or the string “Addicted Studio”.",
